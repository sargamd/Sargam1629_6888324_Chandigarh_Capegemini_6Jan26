@{
    ViewData["Title"] = "Home Page";
}

@{
    ViewData["Title"] = "University Management System";
}

<style>

    body{
        background:linear-gradient(135deg,#74ebd5,#ACB6E5);
        font-family:Arial, Helvetica, sans-serif;
    }

    .container{
        width:80%;
        margin:100px auto;
        text-align:center;
    }

    .title{
        font-size:36px;
        margin-bottom:40px;
        color:#333;
    }

    .grid{
        display:grid;
        grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
        gap:25px;
    }

    .card{
        background:white;
        padding:30px;
        border-radius:12px;
        box-shadow:0px 5px 15px rgba(0,0,0,0.2);
        transition:0.3s;
    }

    .card:hover{
        transform:scale(1.05);
    }

    .btn{
        display:inline-block;
        padding:12px 25px;
        margin-top:10px;
        text-decoration:none;
        border-radius:6px;
        color:white;
        font-weight:bold;
    }

    .student{background:#28a745;}
    .course{background:#007bff;}
    .instructor{background:#ff9800;}
    .department{background:#9c27b0;}
    .enrollment{background:#e91e63;}

</style>

<div class="container">

    <h1 class="title">University Management Dashboard</h1>

    <div class="grid">

        <div class="card">
            <h3>Students</h3>
            <a asp-controller="Students" asp-action="Index" class="btn student">
                Manage Students
            </a>
        </div>

        <div class="card">
            <h3>Courses</h3>
            <a asp-controller="Courses" asp-action="Index" class="btn course">
                Manage Courses
            </a>
        </div>

        <div class="card">
            <h3>Instructors</h3>
            <a asp-controller="Instructors" asp-action="Index" class="btn instructor">
                Manage Instructors
            </a>
        </div>

        <div class="card">
            <h3>Departments</h3>
            <a asp-controller="Departments" asp-action="Index" class="btn department">
                Manage Departments
            </a>
        </div>

        <div class="card">
            <h3>Enrollments</h3>
            <a asp-controller="Enrollments" asp-action="Index" class="btn enrollment">
                Manage Enrollments
            </a>
        </div>

    </div>

</div>
