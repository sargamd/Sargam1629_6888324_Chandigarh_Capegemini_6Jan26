@{
    ViewData["Title"] = "Home Page";
}

<style>

body{
    background: linear-gradient(135deg,#667eea,#764ba2);
    font-family: Arial, Helvetica, sans-serif;
}

.portal-box{
    width:60%;
    margin:120px auto;
    text-align:center;
    background:white;
    padding:50px;
    border-radius:12px;
    box-shadow:0px 8px 25px rgba(0,0,0,0.3);
}

.portal-box h1{
    margin-bottom:20px;
    color:#333;
}

.portal-box p{
    color:#666;
    margin-bottom:30px;
}

.portal-btn{
    padding:15px 40px;
    font-size:20px;
    background:#007bff;
    color:white;
    border-radius:10px;
    text-decoration:none;
    transition:0.3s;
}

.portal-btn:hover{
    background:#0056b3;
    transform:scale(1.05);
}

</style>

<div class="portal-box">

<h1>📚 Library Management System</h1>

<p>Explore our collection of books.</p>

<a asp-controller="Books" asp-action="Index" class="portal-btn">
    View Books
</a>

</div>
