@using Microsoft.AspNetCore.Http

@{
    ViewBag.Title = "Home";
    var user = Context.Session.GetString("Username");
}

<h2 style="text-align:center;">🏠 Home Page</h2>

@if (user != null)
{
    <h3 style="text-align:center; color:blue;">
        Welcome, @user 👋
    </h3>
}

<div style="display:flex; justify-content:center; gap:20px; margin-top:40px;">

    <!-- Login Button -->
    <a href="/Account/Login"
       style="padding:12px 25px; background-color:green; color:white; text-decoration:none; border-radius:8px;">
        🔐 Login
    </a>

    <!-- Dashboard Button -->
    <a href="/Account/Dashboard"
       style="padding:12px 25px; background-color:blue; color:white; text-decoration:none; border-radius:8px;">
        📊 Dashboard
    </a>

</div>

