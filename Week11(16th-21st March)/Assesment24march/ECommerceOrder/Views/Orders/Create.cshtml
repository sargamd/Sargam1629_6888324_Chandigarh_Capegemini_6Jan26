@model ECommerceOrder.Models.Order

@{
    ViewData["Title"] = "Create";
}

<h2>Create Order</h2>

<form asp-action="Create" method="post">

    <div asp-validation-summary="All" class="text-danger"></div>

    <!-- Customer -->
    <div class="form-group">
        <label>Customer</label>
        <select asp-for="CustomerId" class="form-control" asp-items="ViewBag.CustomerId">
            <option value="">-- Select Customer --</option>
        </select>
    </div>

    <!-- Date -->
    <div class="form-group mt-2">
        <label asp-for="OrderDate"></label>
        <input asp-for="OrderDate" class="form-control" />
    </div>

    <!-- Products -->
    <h4 class="mt-3">Products</h4>

    <div class="row mb-2">
        <div class="col">
            <select name="productIds" class="form-control">
                @if (ViewBag.Products != null)
                {
                    foreach (var p in ViewBag.Products)
                    {
                        <option value="@p.ProductId">@p.Name</option>
                    }
                }
            </select>
        </div>

        <div class="col">
            <input name="quantities" type="number" min="1" value="1" class="form-control" />
        </div>
    </div>

    <!-- Shipping -->
    <h4 class="mt-3">Shipping</h4>

    <div class="form-group">
        <input name="ShippingDetail.Address" class="form-control" placeholder="Address" />
    </div>

    <div class="form-group mt-2">
        <input name="ShippingDetail.Status" class="form-control" placeholder="Status" />
    </div>

    <br />

    <button type="submit" class="btn btn-success">Create Order</button>

</form>

<a asp-action="Index">Back</a>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}